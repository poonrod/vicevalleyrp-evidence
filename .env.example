# Root: copy to api/.env and web/.env.local as needed

# API (api/.env) — see api/.env.example for optional DB_HOST, DB_USER, DB_PASSWORD, DB_NAME split vars
DATABASE_URL=mysql://evidence:evidence@127.0.0.1:3306/evidence
SESSION_SECRET=replace-with-long-random-string-min-32-chars
PORT=4000
WEB_APP_URL=http://localhost:3000

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:4000/auth/discord/callback
DISCORD_SUPER_ADMIN_IDS=

FIVEM_API_SECRET=replace-with-shared-secret-for-fivem-server

STORAGE_PROVIDER=r2
PRESIGNED_URL_EXPIRES_SECONDS=900
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Optional S3 / S3-compatible
# STORAGE_PROVIDER=s3
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Web (web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:4000
