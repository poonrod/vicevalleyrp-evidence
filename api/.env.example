# Local Docker / dev (either one line or split vars below — not both):
DATABASE_URL=mysql://evidence:evidence@127.0.0.1:3306/evidence
#
# Hostinger / production: optional split vars (omit DATABASE_URL if you use these; password plain text OK):
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=u123456789_evidence
# DB_NAME=u123456789_evidence
# DB_PASSWORD=your-plain-password
#
# Prisma CLI (`prisma migrate`, `db push`) reads DATABASE_URL from the environment only.
# With split vars, either export a composed DATABASE_URL for that command or keep DATABASE_URL in api/.env for tooling.
SESSION_SECRET=replace-with-long-random-string-min-32-chars
PORT=4000
WEB_APP_URL=http://localhost:3000

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:4000/auth/discord/callback
DISCORD_SUPER_ADMIN_IDS=

FIVEM_API_SECRET=

STORAGE_PROVIDER=r2
PRESIGNED_URL_EXPIRES_SECONDS=900
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
