# Local Docker / dev:
# DATABASE_URL=mysql://evidence:evidence@127.0.0.1:3306/evidence
#
# Hostinger MySQL — use hostname from hPanel (Databases). User/db often look like u123456789_evidence.
# Special characters in the password must be URL-encoded in this string (e.g. ! → %21, @ → %40).
# Example:
# DATABASE_URL="mysql://u787925281_evidence:YOUR_URL_ENCODED_PASSWORD@srvXXXX.hstgr.io:3306/u787925281_evidence"
DATABASE_URL=mysql://evidence:evidence@127.0.0.1:3306/evidence
SESSION_SECRET=replace-with-long-random-string-min-32-chars
PORT=4000
WEB_APP_URL=http://localhost:3000

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:4000/auth/discord/callback
DISCORD_SUPER_ADMIN_IDS=

FIVEM_API_SECRET=

STORAGE_PROVIDER=r2
PRESIGNED_URL_EXPIRES_SECONDS=900
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
