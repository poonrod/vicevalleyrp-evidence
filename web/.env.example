# Browser calls this host for /auth/me, /evidence, etc. Must be the Node API, NOT the Next portal.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Production example (uncomment and adjust — must differ from NEXT_PUBLIC_WEB_APP_URL):
# NEXT_PUBLIC_API_URL=https://api.vicevalleyroleplay.com

# Portal origin where this static site is served (e.g. https://evidence.yourdomain.com). Never use your API URL here — same-origin as the API breaks Next segment loads (/evidence/index.txt) and can corrupt /evidence/view links.
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
# NEXT_PUBLIC_WEB_APP_URL=https://evidence.vicevalleyroleplay.com
